---
import "@/styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 — ANPR</title>
  </head>
  <body class="m-0 min-h-screen flex flex-col items-center justify-center bg-paper font-sans antialiased">
    <main class="flex flex-col items-center gap-6 px-8 text-center">
      <span class="font-mono text-6xl sm:text-7xl font-semibold text-accent tracking-tight">404</span>
      <h1 class="font-display text-2xl font-semibold text-ink m-0 tracking-tight">
        Page not found
      </h1>
      <p class="text-muted text-sm max-w-xs m-0 leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="mt-2 px-6 py-[9px] rounded-lg text-sm font-medium text-white bg-accent hover:bg-accent-2 transition-colors duration-150 no-underline"
      >
        Back to Home
      </a>
    </main>
  </body>
</html>
